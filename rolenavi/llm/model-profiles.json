{
  "version": 6,
  "_notes": {
    "purpose": "RoleNavi pins Codex model and reasoning effort per workflow instead of inheriting the user's Codex CLI defaults.",
    "edit": "Change this file after it is copied to ~/.rolenavi/model-profiles.json, or set ROLENAVI_MODEL_PROFILES to another JSON file.",
    "effort_values": "minimal, low, medium, high, xhigh",
    "override_env": "For one run, set ROLENAVI_CODEX_MODEL and/or ROLENAVI_CODEX_EFFORT."
  },
